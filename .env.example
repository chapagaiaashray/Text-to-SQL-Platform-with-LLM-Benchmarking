# ============================================================
#  Copy this file to `.env` and fill in real values.
# ============================================================

# ---- PostgreSQL (matches docker-compose service "db") ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_HOST=localhost        # use "db" when running INSIDE docker-compose
POSTGRES_PORT=5432

# Databases created by docker/postgres-init/01-init-databases.sql
METADATA_DB=metadata           # app data: query logs, benchmark results
SPIDER_DB=spider               # Spider databases live here, one schema per db_id

# Read-only role used by the sandboxed SQL executor (Week 3).
# This role can SELECT but cannot INSERT/UPDATE/DELETE/DROP.
QUERY_EXECUTOR_USER=query_executor
QUERY_EXECUTOR_PASSWORD=change_me_readonly

# Per-query execution timeout in milliseconds (Week 3 sandbox).
QUERY_TIMEOUT_MS=5000

# ---- LLM provider API keys ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434   # local Llama via Ollama

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
